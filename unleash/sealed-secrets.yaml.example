# Генерация sealed secrets (выполнить когда кластер доступен):
#
# kubectl create secret generic unleash-postgres-credentials \
#   --namespace unleash \
#   --from-literal=username=unleash \
#   --from-literal=password=<STRONG_PASSWORD> \
#   --dry-run=client -o yaml | kubeseal -o yaml > unleash/sealed-secrets.yaml
#
# kubectl create secret generic unleash-credentials \
#   --namespace unleash \
#   --from-literal=admin-api-token=<API_TOKEN> \
#   --dry-run=client -o yaml | kubeseal --merge-into unleash/sealed-secrets.yaml
